#!/usr/bin/env bash
# Render Markdown articles to HTML via Pandoc.
#
# Usage:
#   ./build                    # regenerate stale HTML across articles/ and courses/
#   ./build --all              # regenerate everything
#   ./build <path/to/file.md>  # render one file
#
# Skips any path containing a component starting with _ (e.g., _drafts/).
# See CONVENTIONS.md.

set -euo pipefail
cd "$(dirname "$0")"

command -v pandoc >/dev/null || { echo "pandoc not found. Install: brew install pandoc" >&2; exit 1; }

force=""
single=""

case "${1:-}" in
  --all)         force=1 ;;
  --help|-h)     sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
  "")            ;;
  *)             single="$1" ;;
esac

is_hidden() {
  # True if any path component starts with _
  [[ "$1" =~ (^|/)_ ]]
}

# Exit codes from render_one:
#   0  rendered
#   10 up-to-date (skipped)
#   11 hidden (skipped)
#   20 failed
render_one() {
  local md="$1"
  local rel="${md#./}"

  if is_hidden "$rel"; then
    return 11
  fi

  local html="${md%.md}.html"

  if [ -z "$force" ] && [ -f "$html" ] && [ "$html" -nt "$md" ]; then
    return 10
  fi

  local dir base htmlname
  dir=$(dirname "$md")
  base=$(basename "$md")
  htmlname="${base%.md}.html"

  echo "▶ $rel"
  if ( cd "$dir" && pandoc \
      --standalone \
      --citeproc \
      --from markdown \
      --to html5 \
      --metadata link-citations=true \
      -o "$htmlname" \
      "$base" ); then
    return 0
  else
    return 20
  fi
}

if [ -n "$single" ]; then
  if [ ! -f "$single" ]; then
    echo "Not found: $single" >&2
    exit 1
  fi
  force=1
  rc=0
  render_one "$single" || rc=$?
  [ "$rc" = 20 ] && exit 1 || exit 0
fi

rendered=0
fresh=0
failed=0
failed_files=()

while IFS= read -r md; do
  rc=0
  render_one "$md" || rc=$?
  case "$rc" in
    0)  rendered=$((rendered+1)) ;;
    10|11) fresh=$((fresh+1)) ;;
    20) failed=$((failed+1)); failed_files+=("$md") ;;
  esac
done < <(find ./articles ./courses -name "*.md" -type f 2>/dev/null | sort)

echo
if [ "$rendered" -eq 0 ] && [ "$failed" -eq 0 ]; then
  echo "Nothing to build. ($fresh up-to-date)"
else
  echo "Built: $rendered  Up-to-date: $fresh  Failed: $failed"
fi

if [ "$failed" -gt 0 ]; then
  echo
  echo "Failures:"
  for f in "${failed_files[@]}"; do
    echo "  ✗ ${f#./}"
  done
  echo
  echo "Fix the source files and re-run. './publish' will not proceed while any build fails."
  exit 1
fi
