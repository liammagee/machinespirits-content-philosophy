#!/usr/bin/env bash
# Local preview server for rendered Pandoc output.
#
# Usage:
#   ./serve              # default port 8000
#   ./serve 9000         # custom port
#   ./serve --no-open    # don't open browser
#
# Generates _preview.html (gitignored, indexer-hidden via _ prefix) listing
# all published HTML and any drafts, then starts a Python static server.
#
# This previews ONLY rendered content. For full-site preview with chrome,
# use the machinespirits-website repo with this package linked.

set -euo pipefail
cd "$(dirname "$0")"

PORT=8000
OPEN_BROWSER=1

for arg in "$@"; do
  case "$arg" in
    --no-open)  OPEN_BROWSER=0 ;;
    --help|-h)  sed -n '2,/^$/p' "$0" | sed 's/^# \?//'; exit 0 ;;
    [0-9]*)     PORT="$arg" ;;
  esac
done

PREVIEW="_preview.html"

extract_title() {
  local html="$1"
  local t
  t=$(grep -m1 -oE '<title>[^<]+</title>' "$html" 2>/dev/null | sed 's|<title>||;s|</title>||')
  if [ -z "$t" ]; then
    t=$(grep -m1 -oE '<h1[^>]*>[^<]+</h1>' "$html" 2>/dev/null | sed -E 's|<h1[^>]*>||;s|</h1>||')
  fi
  [ -z "$t" ] && t=$(basename "$html" .html)
  echo "$t"
}

{
  cat <<'HEAD'
<!doctype html>
<html lang="en"><head>
<meta charset="utf-8">
<title>Local Preview — Machine Spirits Content</title>
<style>
  :root { color-scheme: light dark; }
  body { font-family: ui-serif, Charter, Georgia, serif; max-width: 60rem; margin: 2rem auto; padding: 1rem; line-height: 1.6; }
  h1 { font-size: 1.4rem; margin-bottom: 0; }
  .sub { color: #888; font-size: 0.9rem; margin-top: 0; margin-bottom: 2rem; }
  h2 { font-size: 1rem; margin-top: 2rem; padding-bottom: 0.3rem; border-bottom: 1px solid #ddd; }
  ul { list-style: none; padding-left: 0; }
  li { padding: 0.25rem 0; }
  a { color: #6e1923; text-decoration: none; }
  a:hover { text-decoration: underline; }
  .draft, .hidden { color: #999; }
  .pub::before    { content: "● "; color: #2a7; }
  .draft::before  { content: "○ "; color: #c80; }
  .hidden::before { content: "· "; color: #aaa; }
  .meta { color: #aaa; font-size: 0.8rem; margin-left: 0.5rem; font-family: ui-monospace, monospace; }
  @media (prefers-color-scheme: dark) {
    body { background: #1a1a1a; color: #ddd; }
    h2 { border-color: #333; }
    a { color: #ff9aa6; }
    .meta { color: #555; }
  }
</style>
</head><body>
<h1>Local Preview</h1>
<p class="sub">Generated by ./serve. This page is gitignored and indexer-hidden.</p>
HEAD

  echo "<h2>Published</h2><ul>"
  while IFS= read -r html; do
    rel="${html#./}"
    title=$(extract_title "$html")
    printf '  <li class="pub"><a href="%s">%s</a><span class="meta">%s</span></li>\n' \
      "$rel" "$title" "$rel"
  done < <(find articles courses -name "*.html" -type f 2>/dev/null | grep -v "/_" | sort)
  echo "</ul>"

  echo "<h2>Drafts <small style='font-weight:normal;color:#888'>(.md without .html — run <code>./build</code> to publish)</small></h2><ul>"
  drafts_found=0
  while IFS= read -r md; do
    if [ ! -f "${md%.md}.html" ]; then
      drafts_found=1
      rel="${md#./}"
      printf '  <li class="draft">%s</li>\n' "$rel"
    fi
  done < <(find articles courses -name "*.md" -type f 2>/dev/null | grep -v "/_" | sort)
  [ $drafts_found -eq 0 ] && echo "  <li class=\"draft\" style='font-style:italic'>None.</li>"
  echo "</ul>"

  echo "<h2>Hidden <small style='font-weight:normal;color:#888'>(inside _*/ paths)</small></h2><ul>"
  hidden_found=0
  while IFS= read -r f; do
    hidden_found=1
    rel="${f#./}"
    printf '  <li class="hidden">%s</li>\n' "$rel"
  done < <(find articles courses -path "*/_*" -type f \( -name "*.md" -o -name "*.html" \) 2>/dev/null | sort)
  [ $hidden_found -eq 0 ] && echo "  <li class=\"hidden\" style='font-style:italic'>None.</li>"
  echo "</ul>"

  echo "</body></html>"
} > "$PREVIEW"

URL="http://localhost:$PORT/$PREVIEW"

echo
echo "Preview index:    $URL"
echo "Articles browse:  http://localhost:$PORT/articles/"
echo
echo "Press Ctrl+C to stop."
echo

if [ "$OPEN_BROWSER" = 1 ]; then
  ( sleep 0.5 && open "$URL" 2>/dev/null ) &
fi

exec python3 -m http.server "$PORT"
