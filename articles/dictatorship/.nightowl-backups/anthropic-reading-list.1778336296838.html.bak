<footer>
  Progress, dates, and notes are stored in your browser's <code>localStorage</code> under the key
  <code>anthropic-rl-v1</code>. Clearing site data will erase your progress; export by copy-paste before clearing.
  This file is self-contained — share it as-is.
</footer>

</div>

<script>
(function () {
  const STORAGE_KEY = 'anthropic-rl-v1';
  const state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');

  function save() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function fmtDate(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function updateProgress() {
    const entries = document.querySelectorAll('.entry');
    const done = document.querySelectorAll('.entry.done').length;
    const total = entries.length;
    const pct = total ? Math.round((done / total) * 100) : 0;
    document.getElementById('done-count').textContent = done;
    document.getElementById('total-count').textContent = total;
    document.getElementById('pct-display').textContent = pct + '%';
    document.getElementById('progress-bar').style.setProperty('--pct', pct + '%');
  }

  document.querySelectorAll('.entry').forEach(function (entry) {
    const key = entry.dataset.key;
    const check = entry.querySelector('.entry-check');
    const dateSpan = entry.querySelector('.checked-date');
    const notesWrap = entry.querySelector('.notes');
    const textarea = notesWrap.querySelector('textarea');
    const toggle = entry.querySelector('.toggle-notes');

    const stored = state[key] || {};

    if (stored.checked) {
      check.checked = true;
      entry.classList.add('done');
      if (stored.date) dateSpan.textContent = 'read ' + fmtDate(stored.date);
    }
    if (stored.notes) {
      textarea.value = stored.notes;
    }

    check.addEventListener('change', function () {
      if (check.checked) {
        entry.classList.add('done');
        const now = new Date().toISOString();
        state[key] = Object.assign({}, state[key], { checked: true, date: now });
        dateSpan.textContent = 'read ' + fmtDate(now);
      } else {
        entry.classList.remove('done');
        state[key] = Object.assign({}, state[key], { checked: false, date: null });
        dateSpan.textContent = '';
      }
      save();
      updateProgress();
    });

    toggle.addEventListener('click', function () {
      notesWrap.classList.toggle('open');
      if (notesWrap.classList.contains('open')) textarea.focus();
    });

    let saveTimer;
    textarea.addEventListener('input', function () {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(function () {
        state[key] = Object.assign({}, state[key], { notes: textarea.value });
        save();
      }, 400);
    });
  });

  document.getElementById('reset-btn').addEventListener('click', function () {
    if (!confirm('Reset all progress and notes? This cannot be undone.')) return;
    localStorage.removeItem(STORAGE_KEY);
    location.reload();
  });

  updateProgress();
})();
</script>

</body>
</html>
