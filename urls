#!/usr/bin/env bash
# List what's published, drafted, and hidden according to CONVENTIONS.md.
#
# Usage:
#   ./urls                       # all three sections
#   ./urls published             # only published
#   ./urls drafts                # only drafts
#   ./urls hidden                # only hidden
#   ./urls site                  # public URLs derived from published files
#   ./urls site --base <url>     # override base (default https://machinespirits.org)
#   ./urls --plain               # no colour, plain paths only

set -euo pipefail
cd "$(dirname "$0")"

mode="${1:-all}"
plain=""
base="https://machinespirits.org"
for ((i=1; i<=$#; i++)); do
  arg="${!i}"
  [ "$arg" = "--plain" ] && plain=1
  if [ "$arg" = "--base" ]; then
    next=$((i+1))
    base="${!next}"
  fi
done

if [ -z "$plain" ] && [ -t 1 ]; then
  bold=$'\033[1m'; dim=$'\033[2m'
  green=$'\033[32m'; yellow=$'\033[33m'; gray=$'\033[90m'
  reset=$'\033[0m'
else
  bold=""; dim=""; green=""; yellow=""; gray=""; reset=""
fi

list_published() {
  find articles courses -name "*.html" -type f 2>/dev/null \
    | grep -v "/_" \
    | sort
}

list_drafts() {
  find articles courses -name "*.md" -type f 2>/dev/null \
    | grep -v "/_" \
    | sort \
    | while IFS= read -r md; do
        [ -f "${md%.md}.html" ] || echo "$md"
      done
}

list_hidden() {
  find articles courses -path "*/_*" -type f \( -name "*.md" -o -name "*.html" \) 2>/dev/null \
    | sort
}

# Mirror articleService.js toSlug: lowercase, non-alnum -> -, trim, collapse.
to_slug() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

list_site_urls() {
  # Homepage and all course landing pages.
  echo "$base"
  find courses -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
    | sort \
    | while IFS= read -r d; do
        local id="${d#courses/}"
        printf '%s/#/course/%s\n' "$base" "$id"
      done

  # Each published .html becomes a hash-routed URL.
  list_published \
    | while IFS= read -r f; do
        f="${f#./}"
        case "$f" in
          courses/*/course.html)
            : # course landing already emitted above
            ;;
          courses/*/*.html)
            rest="${f#courses/}"
            id="${rest%%/*}"
            file="${rest#*/}"
            stem="${file%.html}"
            printf '%s/#/%s-%s\n' "$base" "$id" "$(to_slug "$stem")"
            ;;
          articles/*/*.html)
            rest="${f#articles/}"
            subdir="${rest%%/*}"
            file="${rest#*/}"
            stem="${file%.html}"
            printf '%s/#/%s-%s\n' "$base" "$subdir" "$(to_slug "$stem")"
            ;;
          articles/*.html)
            file="${f#articles/}"
            stem="${file%.html}"
            printf '%s/#/%s\n' "$base" "$(to_slug "$stem")"
            ;;
        esac
      done
}

print_section() {
  local title="$1" colour="$2" glyph="$3"
  shift 3
  echo "${bold}${title}${reset}"
  if [ "$#" -eq 0 ]; then
    echo "  ${dim}(none)${reset}"
  else
    for f in "$@"; do
      printf "  ${colour}${glyph}${reset} %s\n" "${f#./}"
    done
  fi
  echo
}

case "$mode" in
  published|pub)
    while IFS= read -r f; do printf "%s\n" "${f#./}"; done < <(list_published)
    ;;
  drafts|draft)
    while IFS= read -r f; do printf "%s\n" "${f#./}"; done < <(list_drafts)
    ;;
  hidden)
    while IFS= read -r f; do printf "%s\n" "${f#./}"; done < <(list_hidden)
    ;;
  site|urls|web)
    list_site_urls
    ;;
  all|--plain|"")
    pub=()
    while IFS= read -r f; do pub+=("$f"); done < <(list_published)
    drafts=()
    while IFS= read -r f; do drafts+=("$f"); done < <(list_drafts)
    hidden=()
    while IFS= read -r f; do hidden+=("$f"); done < <(list_hidden)

    echo
    print_section "Published — visible to indexer" "$green" "●" "${pub[@]+"${pub[@]}"}"
    print_section "Drafts — Markdown without rendered HTML (run ./build)" "$yellow" "○" "${drafts[@]+"${drafts[@]}"}"
    print_section "Hidden — inside _*/ paths" "$gray" "·" "${hidden[@]+"${hidden[@]}"}"

    echo "${dim}Summary: ${#pub[@]} published, ${#drafts[@]} drafts, ${#hidden[@]} hidden${reset}"
    ;;
  --help|-h)
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    exit 1
    ;;
esac
