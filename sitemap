def build_toc(article_topics: list[str], course_ids: list[str], other_present: list[str]) -> str:
    links = ['<a href="#articles">Articles</a>', '<a href="#courses">Courses</a>']
    for folder in other_present:
        meta = OTHER_TOP_LEVELS.get(folder, {})
        label = meta.get("name") or humanise(folder)
        links.append(f'<a href="#{escape(folder)}">{escape(label)}</a>')
    for slug, label in (("hegel-essays", "Hegel"), ("ai-tutor", "AI Tutor"), ("vibe-scholarship", "Vibe Scholarship")):
        if slug in article_topics:
            links.append(f'<a href="#{slug}">{label}</a>')
    course_labels = {
        "479": "EPS 479",
        "480": "EPS 480",
        "490": "EPS 490",
        "490-spring-2026": "EPS 490 Spring",
        "590": "EPS 590",
        "dissertation": "Dissertation",
    }
    for cid in course_ids:
        if cid in course_labels:
            links.append(f'<a href="#{cid}">{course_labels[cid]}</a>')
    return "\n    ".join(links)


def render_other_sections(files: list[Path]) -> tuple[str, int, list[str]]:
    """Render each OTHER_TOP_LEVELS folder as its own H2 section.

    Returns (concatenated HTML, total count across all 'other' sections, list of
    folder names that produced output — for TOC).
    """
    blocks = []
    total = 0
    present: list[str] = []
    for folder, meta in OTHER_TOP_LEVELS.items():
        body, count = build_other_section(folder, meta, files)
        if not count:
            continue
        present.append(folder)
        total += count
        blocks.append(
            f'\n<section id="{escape(folder)}">\n'
            f'  <h2>{escape(meta["name"])} <span class="count">{count}</span></h2>\n'
            f'{body}\n'
            f'</section>'
        )
    return "\n".join(blocks), total, present


def render_page(files: list[Path]) -> str:
    from datetime import date

    articles_body, articles_count = build_articles_section(files)
    courses_body, courses_count = build_courses_section(files)
    other_sections, other_count, other_present = render_other_sections(files)
    total = articles_count + courses_count + other_count

    article_topics = sorted({f.parts[1] for f in files if f.parts[0] == "articles"})
    course_ids = sorted({f.parts[1] for f in files if f.parts[0] == "courses"})

    return PAGE.format(
        total=total,
        articles_count=articles_count,
        courses_count=courses_count,
        articles_body=articles_body,
        courses_body=courses_body,
        other_sections=other_sections,
        toc=build_toc(article_topics, course_ids, other_present),
        generated=date.today().isoformat(),
    )


# ---------- Entry point ----------------------------------------------------

def main(argv: list[str]) -> int:
    mode = argv[1] if len(argv) > 1 else ""
    files = list_published()
    html = render_page(files)

    if mode == "--stdout":
        sys.stdout.write(html)
        return 0

    if mode == "--check":
        existing = OUT.read_text(encoding="utf-8") if OUT.exists() else ""
        if existing != html:
            print("sitemap.html is stale. Run ./sitemap to regenerate.", file=sys.stderr)
            return 1
        print("sitemap.html is up to date.")
        return 0

    if mode in ("--help", "-h"):
        # Print the docstring header
        with open(__file__, "r") as f:
            for line in f:
                if line.startswith("# "):
                    print(line[2:].rstrip())
                elif line.startswith("#!"):
                    continue
                else:
                    break
        return 0

    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text(html, encoding="utf-8")
    rel = OUT.relative_to(ROOT)
    print(f"Wrote {rel} ({len(files)} entries).")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
