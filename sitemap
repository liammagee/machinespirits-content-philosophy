#!/usr/bin/env python3
# Generate articles/sitemap.html from the current published content set.
#
# Usage:
#   ./sitemap                # write articles/sitemap.html
#   ./sitemap --stdout       # print to stdout, don't write
#   ./sitemap --check        # exit 1 if the on-disk sitemap is stale
#
# The sitemap is a hand-authored-feeling page listing every published article
# and course material, grouped by topic. Links use the /content/<path> static
# URL scheme so they bypass the SPA and resolve to raw files served by
# express.static.
#
# Title extraction tries, in order:
#   1. `title:` field in YAML frontmatter of the sibling .md
#   2. First markdown `# H1` in the .md body
#   3. First `<h1>` or `<h2>` in the rendered .html
#   4. A humanised version of the filename slug
#
# Topic display names for course folders come from each `course.md`'s title.
# Article topics use a small dict of overrides; new topics get a humanised
# folder name automatically.

from __future__ import annotations

import re
import sys
from html import escape
from pathlib import Path

ROOT = Path(__file__).resolve().parent
OUT = ROOT / "articles" / "sitemap.html"

# ---------- Helpers --------------------------------------------------------

ACRONYMS = {"ai", "ml", "lms", "eps", "caqdas", "llm", "llms", "api", "url", "urls", "pdf"}
LOWERCASE_WORDS = {"and", "or", "the", "of", "in", "on", "with", "a", "an", "for", "to", "from", "by"}


def humanise(slug: str) -> str:
    """Turn 'gen_ai___week_5' into 'Gen AI — Week 5'."""
    s = slug.replace("___", " — ").replace("__", ": ").replace("_", " ").replace("-", " ")
    words = s.split()
    out = []
    for i, w in enumerate(words):
        lw = w.lower().strip(":—")
        if lw in ACRONYMS:
            # Preserve trailing punctuation
            out.append(w.upper())
        elif w.isdigit():
            out.append(w)
        elif i > 0 and lw in LOWERCASE_WORDS:
            out.append(lw)
        elif w in {"—", ":"}:
            out.append(w)
        else:
            out.append(w[:1].upper() + w[1:].lower())
    return " ".join(out)


def is_hidden(path: Path) -> bool:
    return any(part.startswith("_") for part in path.parts)


def list_published() -> list[Path]:
    """Mirror ./urls published: every <root>/**/*.html outside _*/ paths.

    Roots are articles/, courses/, and any folder in OTHER_TOP_LEVELS.
    """
    files = []
    roots = ("articles", "courses", *OTHER_TOP_LEVELS.keys())
    for root_name in roots:
        root_dir = ROOT / root_name
        if not root_dir.exists():
            continue
        for p in root_dir.rglob("*.html"):
            rel = p.relative_to(ROOT)
            if is_hidden(rel):
                continue
            if rel.as_posix() == "articles/sitemap.html":
                continue
            files.append(rel)
    return sorted(files, key=lambda p: p.as_posix())


def read_frontmatter_title(md: Path) -> str | None:
    if not md.exists():
        return None
    text = md.read_text(encoding="utf-8", errors="replace")
    if not text.startswith("---"):
        return None
    end = text.find("\n---", 3)
    if end < 0:
        return None
    fm = text[3:end]
    m = re.search(r"^title:\s*(.+?)\s*$", fm, re.MULTILINE)
    if not m:
        return None
    title = m.group(1).strip()
    if (title.startswith('"') and title.endswith('"')) or (title.startswith("'") and title.endswith("'")):
        title = title[1:-1]
    return title or None


def read_md_h1(md: Path) -> str | None:
    if not md.exists():
        return None
    text = md.read_text(encoding="utf-8", errors="replace")
    # Strip frontmatter
    body = text
    if text.startswith("---"):
        end = text.find("\n---", 3)
        if end > 0:
            body = text[end + 4:]
    m = re.search(r"^# +(.+?)\s*$", body, re.MULTILINE)
    return m.group(1).strip() if m else None


def read_html_heading(html: Path) -> str | None:
    if not html.exists():
        return None
    text = html.read_text(encoding="utf-8", errors="replace")
    for tag in ("h1", "h2"):
        m = re.search(rf"<{tag}[^>]*>(.+?)</{tag}>", text, re.DOTALL | re.IGNORECASE)
        if m:
            inner = re.sub(r"<[^>]+>", "", m.group(1))
            inner = inner.strip()
            if inner:
                return inner
    return None


def normalise_ws(s: str) -> str:
    """Collapse any run of whitespace (including newlines) into a single space."""
    return re.sub(r"\s+", " ", s).strip()


def title_for(rel: Path) -> str:
    """Best-available title for a published HTML file."""
    md = ROOT / rel.with_suffix(".md")
    html = ROOT / rel
    for fn in (read_frontmatter_title, read_md_h1):
        t = fn(md)
        if t:
            return normalise_ws(t)
    t = read_html_heading(html)
    if t:
        return normalise_ws(t)
    return humanise(rel.stem)


