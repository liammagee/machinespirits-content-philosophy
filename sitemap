# ---------- Item ordering --------------------------------------------------

def article_item_key(rel: Path) -> tuple:
    """Sort articles by stem alphabetically."""
    return (rel.stem,)


def course_item_key(rel: Path) -> tuple:
    """Course: course.html first, then by stem in 'natural' order (week-2 < week-10)."""
    stem = rel.stem
    is_course = 0 if stem == "course" else 1
    # Natural sort: split into (text, number) tuples
    parts = re.split(r"(\d+)", stem)
    natural = tuple(int(p) if p.isdigit() else p for p in parts)
    return (is_course, natural)


def marker_for(rel: Path) -> str:
    """A small left-side marker for a list item: course landing, week/lecture number, or generic ▸."""
    stem = rel.stem
    if stem == "course":
        return "§"
    m = re.search(r"(?:lecture|week)[\W_]*(\d+)", stem, re.IGNORECASE)
    if m:
        return m.group(1)
    if "overview" in stem.lower() or "roadmap" in stem.lower():
        return "▤"
    if "question" in stem.lower():
        return "?"
    return "▸"


# ---------- Rendering ------------------------------------------------------

def url_for(rel: Path) -> str:
    return "/content/" + rel.as_posix()


def render_item(rel: Path, title: str) -> str:
    return (
        f'      <li class="item">'
        f'<span class="marker">{escape(marker_for(rel))}</span>'
        f'<a href="{escape(url_for(rel))}">{title}</a>'
        f'<span class="slug">{escape(rel.stem)}</span></li>'
    )


def safe_title_html(title: str) -> str:
    """Allow a small set of inline tags from frontmatter titles; escape everything else."""
    # Pandoc-style markdown emphasis: *foo* → <em>foo</em>
    def emph(m): return f"<em>{escape(m.group(1))}</em>"
    title = re.sub(r"\*([^*]+)\*", emph, title)
    # Strip any other HTML for safety, but keep <em>
    return re.sub(r"<(?!/?em\b)[^>]+>", "", title)


def render_group(label: str, slug: str, blurb: str | None, items: list[tuple[Path, str]], path_prefix: str) -> str:
    head_id = f' id="{escape(slug)}"' if slug else ""
    blurb_html = f'    <p class="group-blurb">{blurb}</p>\n' if blurb else ""
    items_html = "\n".join(render_item(rel, safe_title_html(title)) for rel, title in items)
    return (
        f'  <div class="group" data-group="{escape(slug)}">\n'
        f'    <div class="group-head"{head_id}><h3>{label}</h3>'
        f'<span class="group-tag">{escape(path_prefix)}</span></div>\n'
        f'{blurb_html}'
        f'    <ul class="items">\n{items_html}\n    </ul>\n'
        f'  </div>\n'
    )


def build_articles_section(files: list[Path]) -> tuple[str, int]:
    """Return (HTML, item count)."""
    # Group by topic folder
    groups: dict[str, list[Path]] = {}
    for rel in files:
        if rel.parts[0] != "articles":
            continue
        topic = rel.parts[1]
        groups.setdefault(topic, []).append(rel)

    parts = []
    count = 0

    # Order topics: those in ARTICLE_TOPICS first (in dict order), then any extras alphabetically.
    ordered_topics = list(ARTICLE_TOPICS.keys()) + sorted(g for g in groups if g not in ARTICLE_TOPICS)
    seen = set()
    for topic in ordered_topics:
        if topic in seen or topic not in groups:
            continue
        seen.add(topic)
        meta = ARTICLE_TOPICS.get(topic, {})
        name = meta.get("name") or humanise(topic)
        blurb = meta.get("blurb")
        items = sorted(groups[topic], key=article_item_key)
        rendered_items = [(rel, title_for(rel)) for rel in items]
        parts.append(render_group(escape(name), topic, blurb, rendered_items, f"articles/{topic}"))
        count += len(items)

    body = "\n".join(parts)
    return body, count


def build_other_section(folder: str, meta: dict, files: list[Path]) -> tuple[str, int]:
    """Render one top-level 'other' folder.

    Flat files (folder/foo.html) share a single group named after the section.
    Files with a sub-folder (folder/sub/foo.html) get one group per sub-folder.
    """
    rels = [f for f in files if f.parts[0] == folder]
    if not rels:
        return "", 0

    by_sub: dict[str, list[Path]] = {}
    flat: list[Path] = []
    for rel in rels:
        if len(rel.parts) >= 3:
            by_sub.setdefault(rel.parts[1], []).append(rel)
        else:
            flat.append(rel)

    parts = []
    count = 0

    if flat:
        items = sorted(flat, key=article_item_key)
        rendered = [(rel, title_for(rel)) for rel in items]
        parts.append(render_group(escape(meta["name"]), folder, meta.get("blurb"), rendered, folder))
        count += len(items)

    for sub in sorted(by_sub):
        items = sorted(by_sub[sub], key=article_item_key)
        rendered = [(rel, title_for(rel)) for rel in items]
        parts.append(
            render_group(
                escape(humanise(sub)),
                f"{folder}-{sub}",
                None,
                rendered,
                f"{folder}/{sub}",
            )
        )
        count += len(items)

    return "\n".join(parts), count


def build_courses_section(files: list[Path]) -> tuple[str, int]:
    groups: dict[str, list[Path]] = {}
    for rel in files:
        if rel.parts[0] != "courses":
            continue
        cid = rel.parts[1]
        groups.setdefault(cid, []).append(rel)

    parts = []
    count = 0

    # Order: known courses first (in COURSE_BLURBS order), then extras alphabetically
    known = list(COURSE_BLURBS.keys())
    ordered_ids = known + sorted(g for g in groups if g not in COURSE_BLURBS)
    seen = set()
    for cid in ordered_ids:
        if cid in seen or cid not in groups:
            continue
        seen.add(cid)

        course_html = ROOT / "courses" / cid / "course.html"
        if cid in COURSE_NAMES:
            display = COURSE_NAMES[cid]
        else:
            course_title = title_for(Path("courses") / cid / "course.html") if course_html.exists() else humanise(cid)
            prefix = COURSE_PREFIXES.get(cid, "")
            display = f"{prefix}{course_title}"

        # Wrap the heading with a link to the course landing if it exists
        if course_html.exists():
            display_html = f'<a href="{escape(url_for(Path("courses") / cid / "course.html"))}">{escape(display)}</a>'
        else:
            display_html = escape(display)

        items = sorted(groups[cid], key=course_item_key)
        rendered_items = [(rel, title_for(rel)) for rel in items]
        blurb = COURSE_BLURBS.get(cid)
        parts.append(render_group(display_html, cid, blurb, rendered_items, f"courses/{cid}"))
        count += len(items)

    body = "\n".join(parts)
    return body, count


